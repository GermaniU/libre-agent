# LocalCowork — copiá este archivo a `.env` y ajustá lo que uses.
#   cp .env.example .env
# NADA acá es obligatorio salvo tener ollama corriendo. Todo lo demás degrada
# solo si falta (sin corpus no hay vault_search, sin token no arranca el bot, etc.).

# --- Núcleo (lo único imprescindible) ---
# ollama local; dejalo así si corre en la misma máquina.
OLLAMA_URL=http://localhost:11434
# Modelo por defecto. Si no lo tenés, la UI elige solo el primero disponible.
DEFAULT_MODEL=llama3.2

# --- GPU (para marcar qué modelos entran en la VRAM) ---
VRAM_GB=12

# --- RAG sobre un vault (OPCIONAL) ---
# Servidor de corpus/Qdrant propio. Sin esto, vault_search simplemente no encuentra nada.
CORPUS_URL=http://localhost:5099/api
CORPUS_KEY=cambiá-esto
RAG_TOPK=6
# Carpeta del vault (Obsidian u otra) para vault_read/vault_recent.
VAULT_DIR=/ruta/a/tu/vault

# --- Memoria persistente vía MCP (OPCIONAL) ---
# Nombre del server (en tu mcp.json) que expone los tools memory_* (search/save/…).
# Con "💾 Memoria persistente" ON, sus tools se le pasan al modelo, además del recall+
# guardado automático. El server debe cumplir el contrato de docs/memory-mcp.md.
# Debe coincidir con una clave de mcp.json. Si no existe → solo recall pasivo.
MEMORY_MCP_SERVER=mcp-memory

# --- Filesystem donde el agente crea proyectos/scripts ---
# run_cmd/write_file quedan confinados acá. Apuntalo a una carpeta de pruebas.
WORKSPACE_DIR=/ruta/a/tu/workspace

# --- Imágenes (OPCIONAL) ---
COMFYUI_URL=http://localhost:8188

# --- Bot de Telegram (OPCIONAL — solo si corrés run-bot.sh) ---
# Token de @BotFather y tu user id numérico (el bot solo te responde a vos).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER=
